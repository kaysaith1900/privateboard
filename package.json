{
  "name": "privateboard",
  "version": "0.1.6",
  "description": "PrivateBoard · your private board meeting, on call. Local-first, multi-agent thinking amplifier.",
  "type": "module",
  "bin": {
    "privateboard": "dist/cli.js"
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch --onSuccess \"node dist/cli.js --no-open\"",
    "build": "tsup",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync-version": "node scripts/sync-version.mjs",
    "regen-avatars": "node scripts/regen-avatars.mjs",
    "prepublishOnly": "npm run sync-version && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaysaith1900/privateboard.git"
  },
  "homepage": "https://github.com/kaysaith1900/privateboard#readme",
  "bugs": {
    "url": "https://github.com/kaysaith1900/privateboard/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.5",
    "@ai-sdk/google": "^1.2.10",
    "@ai-sdk/openai": "^1.3.13",
    "@ai-sdk/openai-compatible": "^0.2.4",
    "@ai-sdk/xai": "^1.2.10",
    "@hono/node-server": "^1.13.7",
    "ai": "^4.3.16",
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0",
    "hono": "^4.6.14",
    "open": "^10.1.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "keywords": [
    "ai",
    "multi-agent",
    "local-first",
    "thinking",
    "boardroom"
  ]
}
